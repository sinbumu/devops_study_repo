# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # 공통
  config.vm.box = "cloud-image/ubuntu-24.04"
  config.vm.boot_timeout = 3600

  # ----------------------------
  # 1) GitLab Server VM
  # ----------------------------
  config.vm.define "gitlab" do |cfg|
    cfg.vm.hostname = "gitlab.local"

    cfg.vm.network "forwarded_port", guest: 80, host: 8080
    cfg.vm.network "forwarded_port", guest: 22, host: 8022
    cfg.vm.network "private_network", ip: "192.168.33.44"

    cfg.vm.synced_folder ".", "/vagrant", type: "rsync", rsync__exclude: [".git/"]

    cfg.vm.provider "virtualbox" do |vb|
      vb.name = "gitlab.local"
      vb.cpus = 2
      vb.memory = "4096"
    end

    cfg.vm.provision "shell", inline: <<-SHELL
      sudo apt-get update
      sudo apt-get install -y curl wget ca-certificates

      sudo curl -L --output /usr/local/bin/gitlab-runner \
        https://gitlab-runner-downloads.s3.amazonaws.com/latest/binaries/gitlab-runner-linux-amd64

      sudo chmod +x /usr/local/bin/gitlab-runner

      if ! id -u gitlab-runner >/dev/null 2>&1; then
        sudo useradd --comment 'GitLab Runner' --create-home gitlab-runner --shell /bin/bash
      fi

      sudo gitlab-runner install --user=gitlab-runner --working-directory=/home/gitlab-runner || true
      sudo gitlab-runner start || true

      echo "Runner installation completed."
    SHELL
  end

  # ----------------------------
  # 2) GitLab Runner VM
  # ----------------------------
  config.vm.define "runner" do |cfg|
    cfg.vm.hostname = "runner.local"

    cfg.vm.network "forwarded_port", guest: 22, host: 8023
    cfg.vm.network "private_network", ip: "192.168.33.45"

    cfg.vm.synced_folder ".", "/vagrant", type: "rsync", rsync__exclude: [".git/"]

    cfg.vm.provider "virtualbox" do |vb|
      vb.name = "runner.local"
      vb.cpus = 2
      vb.memory = "2048"
    end

    cfg.vm.provision "shell", inline: <<-SHELL
      sudo apt-get update
      sudo apt-get install -y curl wget ca-certificates

      # GitLab Runner binary 설치
      sudo curl -L --output /usr/local/bin/gitlab-runner \
        https://gitlab-runner-downloads.s3.amazonaws.com/latest/binaries/gitlab-runner-linux-amd64

      sudo chmod +x /usr/local/bin/gitlab-runner

      # gitlab-runner 사용자 생성
      if ! id -u gitlab-runner >/dev/null 2>&1; then
        sudo useradd --comment 'GitLab Runner' --create-home gitlab-runner --shell /bin/bash
      fi

      # 서비스 등록 및 시작
      sudo gitlab-runner install --user=gitlab-runner --working-directory=/home/gitlab-runner
      sudo gitlab-runner start

      echo "Runner 설치 완료"
    SHELL
  end
end